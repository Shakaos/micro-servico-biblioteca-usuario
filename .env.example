# 🎮 CONFIGURAÇÃO DO AMBIENTE - Biblioteca do Usuário GameVerse
# Este arquivo mostra quais configurações eu preciso para funcionar no Supabase/PostgreSQL

# ============================================
# CONFIGURAÇÕES DO BANCO DE DADOS (SUPABASE)
# ============================================
# Obtenha这些 informações no painel do Supabase → Settings → Database
DB_HOST=seu-projeto.supabase.co
DB_USER=postgres
DB_PASSWORD=sua-senha-do-banco
DB_NAME=postgres
DB_PORT=5432

# ============================================
# CONFIGURAÇÕES DO SERVIÇO
# ============================================
# Porta onde eu rodo (porta 3005 para não conflitar com outros serviços)
PORT=3005

# Segredo JWT para autenticação (use uma string aleatória segura)
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao

# ============================================
# CONFIGURAÇÕES JWT (do PDF do trabalho)
# ============================================
JWT_ISSUER=https://sistema-distribuido-trabalho-faculd.vercel.app
